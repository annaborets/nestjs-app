# Application
NODE_ENV=development
PORT=3000

# Database (used when running outside Docker)
DATABASE_URL=postgres://appuser:apppassword@localhost:5432/appdb
DATABASE_SSL=false

# Auth
JWT_SECRET=your-super-secret-key-change-in-production

# Seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!

# S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=lesson9-files-private
S3_ENDPOINT=http://localhost:9002
CLOUDFRONT_BASE_URL=http://localhost:9002/lesson9-files-private

# Docker Compose overrides (optional)
DB_USER=appuser
DB_PASSWORD=apppassword
DB_NAME=appdb

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Payments gRPC
PAYMENTS_GRPC_URL=payments:5001
PAYMENTS_GRPC_TIMEOUT_MS=5000
PAYMENTS_GRPC_RETRY_ATTEMPTS=3
PAYMENTS_GRPC_RETRY_DELAY_MS=200